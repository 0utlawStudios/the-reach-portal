{
  "name": "the-reach-portal",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.10.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=moderate",
    "audit:prod": "npm audit --omit=dev --audit-level=moderate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:media": "playwright test e2e/upload-runtime.spec.ts --config=playwright.config.ts",
    "e2e:prod": "PLAYWRIGHT_BASE_URL=https://thereach.ten80ten.com playwright test --config=playwright.config.ts",
    "verify:target": "node scripts/verify-the-reach-target.mjs",
    "quality": "npm run audit && npm run lint && npm run typecheck && npm test && npm run build",
    "preflight": "npm ci && npm run quality",
    "db:diff": "supabase db diff --schema public",
    "db:types": "supabase gen types typescript --project-id \"$SUPABASE_PROJECT_ID\" --schema public > src/lib/database.types.ts",
    "db:types:check": "tsx scripts/db-types-check.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.108.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.41.0",
    "google-auth-library": "^10.9.0",
    "heic-decode": "^2.1.0",
    "lucide-react": "^0.577.0",
    "next": "^16.2.9",
    "nodemailer": "^9.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.7",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^24",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "jsdom": "^25.0.1",
    "supabase": "^2.108.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
