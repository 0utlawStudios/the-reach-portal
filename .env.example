# Core app
NEXT_PUBLIC_SITE_URL=https://thereach.ten80ten.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Supabase CLI and CI drift checks
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_ACCESS_TOKEN=sbp_replace-with-supabase-access-token

# Google Drive uploads and media streaming
GOOGLE_SERVICE_ACCOUNT_JSON=base64-encoded-service-account-json
GOOGLE_DRIVE_ROOT_FOLDER_ID=replace-with-drive-root-folder-id
DRIVE_STREAM_SIGNING_SECRET=replace-with-random-secret
DRIVE_UPLOAD_SESSION_SECRET=replace-with-random-secret
MEDIA_PLAYBACK_SIGNING_SECRET=replace-with-random-secret
AI_ASSET_SIGNING_SECRET=replace-with-random-secret

# Webhooks and workers
PUBLISHER_WEBHOOK_HMAC_SECRET=replace-with-random-secret
PUBLISHER_WEBHOOK_SECRET=temporary-rollout-fallback-only
SUPABASE_WEBHOOK_HMAC_SECRET=replace-with-random-secret
SUPABASE_WEBHOOK_SECRET=temporary-rollout-fallback-only
AI_WORKER_HMAC_SECRET=replace-with-random-secret
AI_WORKER_TRIGGER_SECRET=replace-with-random-secret
CRON_SECRET=replace-with-random-secret

# Health checks
HEALTH_CHECK_SECRET=replace-with-random-secret
HEALTH_DETAIL_SECRET=replace-with-separate-random-secret
N8N_HEALTH_WEBHOOK_URL=https://n8n.example/webhook/health

# Email and alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=alerts@example.com
SMTP_PASS=replace-with-smtp-app-password
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_DNS_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
SUPPORT_NOTIFY_EMAIL=support@example.com
UPLOAD_ALERT_EMAIL=uploads@example.com
UPLOAD_FAILURE_NOTIFY_EMAIL=uploads@example.com

# Telegram notifications
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=replace-with-chat-id
UPLOAD_ALERT_TELEGRAM_CHAT_ID=replace-with-chat-id

# AI studio
STUDIO_ENABLED=false
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_IMAGE_API_KEY=replace-with-openai-api-key
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_VERIFIER_MODEL=gpt-4o-mini
OPENAI_PROMPT_VERSION=2026-05-13.v1
OPENAI_DAILY_CAP_USD=25
OPENAI_PER_ROW_CAP_USD=5
OPENAI_PRICE_TEXT_IN=0.0025
OPENAI_PRICE_TEXT_OUT=0.01
OPENAI_PRICE_IMAGE=0.50
OPENAI_PRICE_VERIFIER_IN=0.00015
OPENAI_PRICE_VERIFIER_OUT=0.0006

# Runtime QA
PLAYWRIGHT_BASE_URL=http://localhost:3000
PLAYWRIGHT_RUN_ID=local-upload-smoke
PLAYWRIGHT_OUTPUT_DIR=playwright-report
QA_ALLOW_PROD_UPLOADS=0
QA_ALLOW_PROD_E2E=0
QA_ALLOW_PROD_DRAG=0

# Release target guard
VERCEL_PROJECT_NAME=the-reach-portal
